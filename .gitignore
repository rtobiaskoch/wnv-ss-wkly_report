# R session artifacts
.Rproj.user
.Rhistory
.RData
.Ruserdata

# Sensitive / credentials — never commit these
.Renviron
*.json
*_key.json
*service_account_key*.R

# Large input data (download from Google Drive instead)
1_input/*/all_species/
1_input/*/datasheet/
1_input/*/pcr/
1_input/*/platemap/

# Intermediate & output files (regenerated by pipeline)
2_mid/*.RData
2_mid/*.csv
2_mid/*.png
3_output/plots/
3_output/*.xlsx
3_output/*.html

# renv lock cache (keep renv.lock, ignore library cache)
renv/library/
renv/staging/

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
